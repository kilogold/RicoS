{
  "name": "ricos",
  "private": true,
  "workspaces": [
    "web",
    "kitchen-relay",
    "packages/shared"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "preinstall": "bun scripts/enforce-bun-install.mjs",
    "dev:web": "bun run --filter './web' dev",
    "dev:kitchen": "bun run --filter './kitchen-relay' dev",
    "build": "bun run --filter './web' build",
    "lint": "bun run --filter './web' lint"
  },
  "packageManager": "bun@1.2.0"
}
