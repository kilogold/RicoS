{
  "name": "ricos",
  "private": true,
  "workspaces": [
    "web",
    "kitchen-relay",
    "packages/shared"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "preinstall": "bun scripts/enforce-bun-install.mjs",
    "db:nuke": "bun --env-file=.env.preview --env-file=.env.local scripts/nuke-turso-db.mjs",
    "db:nuke:production": "bun --env-file=.env.production --env-file=.env.local scripts/nuke-turso-db.mjs",
    "db:clear-orders": "bun --env-file=.env.preview --env-file=.env.local scripts/clear-orders-turso-db.mjs",
    "db:clear-orders:production": "bun --env-file=.env.production --env-file=.env.local scripts/clear-orders-turso-db.mjs",
    "dev:web": "bun --env-file=../.env.preview --env-file=../.env.local run --cwd web dev",
    "dev:web:production": "bun --env-file=../.env.production --env-file=../.env.local run --cwd web dev",
    "dev:kitchen": "bun --env-file=../.env.preview --env-file=../.env.local run --cwd kitchen-relay dev",
    "dev:kitchen:production": "bun --env-file=../.env.production --env-file=../.env.local run --cwd kitchen-relay dev",
    "start:kitchen": "bun --env-file=../.env.preview --env-file=../.env.local run --cwd kitchen-relay start",
    "start:kitchen:production": "bun --env-file=../.env.production --env-file=../.env.local run --cwd kitchen-relay start",
    "print:test": "bun --env-file=../.env.preview --env-file=../.env.local run --cwd kitchen-relay print:test",
    "print:test:production": "bun --env-file=../.env.production --env-file=../.env.local run --cwd kitchen-relay print:test",
    "build": "bun --env-file=../.env.preview --env-file=../.env.local run --cwd web build",
    "build:production": "bun --env-file=../.env.production --env-file=../.env.local run --cwd web build",
    "lint": "bun --env-file=../.env.preview --env-file=../.env.local run --cwd web lint",
    "lint:production": "bun --env-file=../.env.production --env-file=../.env.local run --cwd web lint",
    "verify:menu-catalog": "bun scripts/verify-menu-catalog-version.mjs"
  },
  "packageManager": "bun@1.2.0",
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@solana-commerce/connector": "^0.1.0",
    "@solana-commerce/headless": "^0.1.1",
    "@solana-commerce/kit": "0.1.1",
    "@solana-commerce/react": "0.1.1",
    "@solana-commerce/solana-pay": "0.1.1",
    "@tanstack/react-query": "^5.99.2"
  }
}
