# Shared defaults for the monorepo.
# Copy to .env at repo root.
# Do not put secrets in this file.

# Required: Turso libSQL URL for commerce, menu_versions, webhooks, kitchen dispatch (single app DB)
TURSO_DATABASE_URL=libsql://your-db-name.your-region.turso.io
# Turso auth token is a secret — set TURSO_DATABASE_AUTH_TOKEN in .env.local (see .env.local.example).
# Staff menu publish reads menu.json from GitHub raw (main). Set MENU_PUBLISH_MENU_JSON_URL in .env.local / Vercel (see .env.local.example).

# Required: kitchen-relay HTTP port (used for GET /health)
KITCHEN_RELAY_PORT=4000

# Required: kitchen-relay printer adapter (`console` or `lp`)
KITCHEN_PRINTER_ADAPTER=console

# Optional: printing relay → web backend base URL
# - local testing:  http://127.0.0.1:3000
# - remote testing: https://your-domain.vercel.app
KITCHEN_BACKEND_BASE_URL=http://127.0.0.1:3000

# Optional: append printed tickets to this file
# KITCHEN_PRINT_LOG=./kitchen-print.log

# Printer A target (required for ip/lp): IP host or CUPS queue id
# KITCHEN_IP_PRINTER_A_HOST=192.168.1.100

# Printer B target (optional): any value enables dual-printer mode; unset = single-printer (all chits on A)
# KITCHEN_IP_PRINTER_B_HOST=192.168.1.101

# Optional retry behavior for printing
# KITCHEN_PRINT_MAX_ATTEMPTS=5
# KITCHEN_PRINT_RETRY_INITIAL_DELAY_MS=200

# Optional: poll interval for pending print jobs when PRINT_BELL_QUEUE_URL is unset (local dev; ms)
# KITCHEN_PRINT_POLL_INTERVAL_MS=10000

# Optional: SQS PrintBell — same queue URL on web (publisher) and kitchen-relay (consumer). Omit locally.
# PRINT_BELL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/PrintBell
# AWS region for SQS (or infer from queue hostname sqs.<region>.amazonaws.com)
# AWS_REGION=us-east-1

# Required for Solana polling ingestion
HELIUS_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
HELIUS_MERCHANT_RECIPIENT=EEHj6a2oScEN2nKT7rN9n2UKT2jLbGQtJnNK5cC5MDJb

# Optional: backend polling cadence for pending Solana references
# SOLANA_POLL_INTERVAL_MS=2000

# Optional: Helius webhook ingestion toggle (disabled by default)
# HELIUS_WEBHOOK_ENABLED=0

# Menu source for publish: GitHub raw URL (production = main branch permalink), not the deployment bundle.
# Example: https://raw.githubusercontent.com/<org>/<repo>/main/packages/shared/src/menu.json
MENU_PUBLISH_MENU_JSON_URL=https://raw.githubusercontent.com/your-org/RicoS/main/packages/shared/src/menu.json

# Store wall-clock times (America/Puerto_Rico in code), 24h HH:MM. Half-open: open [OPEN,LAST), last call [LAST,CLOSE).
STORE_OPEN_TIME=08:00
STORE_LAST_CALL_TIME=20:00
STORE_CLOSE_TIME=21:00
# Optional: 1 = always allow ordering. 2 = browse-only.
# STORE_HOURS_OVERRIDE=
