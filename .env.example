# Copy to web/.env.local for the Next.js app, and kitchen-relay/.env for the relay (or export in shell).

# Stripe — get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Kitchen relay — from `stripe listen` (CLI) or Stripe Dashboard webhook signing secret (production)
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: append printed tickets to this file (kitchen-relay)
# KITCHEN_PRINT_LOG=./kitchen-print.log

# Optional: kitchen-relay HTTP port (default 4000)
# KITCHEN_RELAY_PORT=4000
