# RicoS environment template.
#
# Copy to gitignored files at repo root:
#   .env.preview     — default for root scripts (bun run dev:web, etc.)
#   .env.production  — use with :production scripts (bun run dev:web:production)
#
# Optional: .env.local overrides any value in whichever suffixed file is active.
#
# Preview vs production — vars that typically differ:
#   TURSO_DATABASE_URL              preview DB  |  production DB
#   STRIPE_*                        sk_test_/pk_test_  |  sk_live_/pk_live_
#   KITCHEN_BACKEND_BASE_URL        preview Vercel URL or http://127.0.0.1:3000  |  production apex URL
#   WEBAUTHN_RP_ID                  localhost  |  production apex host (e.g. example.com)
#   WEBAUTHN_ALLOWED_ORIGINS        preview/ngrok origins  |  usually unset in production
#   HELIUS_SOLANA_CLUSTER           devnet  |  mainnet  (same value as NEXT_PUBLIC_HELIUS_SOLANA_CLUSTER)
#
# All other vars are usually the same shape across environments; adjust per deploy target.

# --- Database (Turso) ---

TURSO_DATABASE_URL=libsql://your-db-name.your-region.turso.io
TURSO_DATABASE_AUTH_TOKEN=eyJ...

# --- Stripe ---

# Preview: https://dashboard.stripe.com/test/apikeys
# Production: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Solana ---

HELIUS_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
HELIUS_MERCHANT_RECIPIENT=EEHj6a2oScEN2nKT7rN9n2UKT2jLbGQtJnNK5cC5MDJb
NEXT_PUBLIC_HELIUS_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_HELIUS_MERCHANT_RECIPIENT=EEHj6a2oScEN2nKT7rN9n2UKT2jLbGQtJnNK5cC5MDJb
HELIUS_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_HELIUS_SOLANA_CLUSTER=devnet

# Helius RPC (checkout proxy + staff refunds) and enhanced tx API
# HELIUS_API_KEY=

# Staff Solana refunds — merchant signing key (base58); must match HELIUS_MERCHANT_RECIPIENT
# HELIUS_MERCHANT_PRIVATE_KEY=

# Optional Helius webhook ingestion (polling is primary)
# HELIUS_WEBHOOK_ENABLED=0
# HELIUS_WEBHOOK_AUTH_HEADER_NAME=x-helius-auth
# HELIUS_WEBHOOK_AUTH_HEADER_VALUE=change-me-random-secret

# --- Kitchen relay ---

KITCHEN_RELAY_PORT=4000
KITCHEN_PRINTER_ADAPTER=console

# Preview: preview Vercel URL or http://127.0.0.1:3000 — Production: production apex URL
KITCHEN_BACKEND_BASE_URL=http://127.0.0.1:3000

# Optional: append printed tickets to this file
# KITCHEN_PRINT_LOG=./kitchen-print.log

# Printer A target (required for ip/lp): IP host or CUPS queue id
# KITCHEN_IP_PRINTER_A_HOST=192.168.1.100

# Printer B target (optional): any value enables dual-printer mode
# KITCHEN_IP_PRINTER_B_HOST=192.168.1.101

# Optional retry behavior for printing
# KITCHEN_PRINT_MAX_ATTEMPTS=5
# KITCHEN_PRINT_RETRY_INITIAL_DELAY_MS=200

# Poll interval when PRINT_BELL_QUEUE_URL is unset (local dev; ms)
# KITCHEN_PRINT_POLL_INTERVAL_MS=10000

# Optional: relay → backend print-ack auth (same value in web + kitchen-relay)
# PRINT_ACK_SECRET=change-me

# --- Staff / admin ---

STAFF_OPERATIONS_SECRET=change-me-long-random-secret
ADMIN_SETUP_SECRET=change-me-long-random-secret
MAX_ALLOWED_PASSKEYS=5

# Preview: localhost — Production: apex host (e.g. example.com)
WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=RicoS Admin
# WEBAUTHN_ALLOWED_ORIGINS=https://your-preview.vercel.app

CRON_SECRET=change-me-long-random-secret

# Menu catalog (RicoS-Menu repo). Raw URL selects owner/repo/branch/path; runtime reads via GitHub Contents API.
# Preview/local default:
MENU_PUBLISH_MENU_JSON_URL=https://raw.githubusercontent.com/your-org/RicoS-Menu/preview/menu.json
# Production (Vercel Production env only):
# MENU_PUBLISH_MENU_JSON_URL=https://raw.githubusercontent.com/your-org/RicoS-Menu/main/menu.json

# GitHub PAT: required for staff publish; recommended on Vercel for Contents API rate limits.
# RicoS-Menu CI revalidate URL secrets live in the Menu repo (RICOS_PREVIEW_REVALIDATE_URL, RICOS_PRODUCTION_REVALIDATE_URL).
# GITHUB_TOKEN=ghp_...

# --- Store hours (America/Puerto_Rico in code), 24h HH:MM ---

STORE_OPEN_TIME=08:00
STORE_LAST_CALL_TIME=20:00
STORE_CLOSE_TIME=21:00
# Optional: 1 = always allow ordering. 2 = browse-only.
# STORE_HOURS_OVERRIDE=

# --- AWS / PrintBell (optional locally) ---

# PRINT_BELL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/PrintBell
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
