{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ricos: dev — webhook-proxy",
      "type": "shell",
      "command": "bun run dev:webhook-proxy",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "${env:HOME}/.bun/bin:/opt/homebrew/bin:/usr/local/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "showReuseMessage": false
      }
    },
    {
      "label": "ricos: dev — kitchen-relay",
      "type": "shell",
      "command": "bun run dev:kitchen",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "${env:HOME}/.bun/bin:/opt/homebrew/bin:/usr/local/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "showReuseMessage": false
      }
    },
    {
      "label": "ricos: dev — web",
      "type": "shell",
      "command": "bun run dev:web",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "${env:HOME}/.bun/bin:/opt/homebrew/bin:/usr/local/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "showReuseMessage": false
      }
    },
    {
      "label": "ricos: dev — stop bootstrap",
      "type": "shell",
      "command": "for p in 3000 4000; do lsof -ti tcp:$p | xargs kill -15 2>/dev/null || true; done",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "showReuseMessage": false
      }
    },
    {
      "label": "RicoS: Dev bootstrap",
      "dependsOn": [
        "ricos: dev — webhook-proxy",
        "ricos: dev — kitchen-relay",
        "ricos: dev — web"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
