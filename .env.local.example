# Local secrets and machine-specific overrides.
# Copy to .env.local at repo root (gitignored).
# Keep non-secret runtime config in .env (ports, printer adapter).

# Stripe — get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Web backend webhooks — from Stripe CLI or Stripe Dashboard webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Turso database auth token (secret)
TURSO_DATABASE_AUTH_TOKEN=eyJ...

# Staff menu publish — Bearer token for POST /api/staff/menu/publish (same value in Authorization header)
STAFF_MENU_PUBLISH_SECRET=change-me-long-random-secret

# One-time bootstrap for first admin passkey (long random secret)
ADMIN_SETUP_SECRET=change-me-long-random-secret

# Max admin passkeys allowed (default 5)
MAX_ALLOWED_PASSKEYS=5

# WebAuthn RP ID — production: your apex host (e.g. example.com), local: localhost
WEBAUTHN_RP_ID=localhost

# Optional display name (default RicoS Admin)
# WEBAUTHN_RP_NAME=RicoS Admin

# Optional comma-separated extra origins (Vercel previews, ngrok)
# WEBAUTHN_ALLOWED_ORIGINS=https://your-preview.vercel.app

# Vercel Cron — Bearer token for GET /api/cron/expire-pending-orders (production: vercel env add CRON_SECRET production)
CRON_SECRET=change-me-long-random-secret

# Optional: GitHub PAT for private repos (contents read). Public main does not need this.
# GITHUB_TOKEN=ghp_...

# Optional Helius webhook ingestion toggle
# HELIUS_WEBHOOK_ENABLED=1
#
# Optional Helius webhook auth gate
# Polling is primary ingestion; this only applies if webhook ingestion is enabled.
# HELIUS_WEBHOOK_AUTH_HEADER_NAME=x-helius-auth
# HELIUS_WEBHOOK_AUTH_HEADER_VALUE=change-me-random-secret

# Optional: relay → backend print-ack auth (set same value in web + kitchen-relay env)
# PRINT_ACK_SECRET=change-me

# Optional override for remote kitchen relay testing 
# KITCHEN_BACKEND_BASE_URL=https://your-domain.vercel.app

# Optional: AWS credentials for PrintBell (web: SendMessage; kitchen-relay: ReceiveMessage/DeleteMessage). Use IAM user or instance role on the relay host.
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Optional: same queue as kitchen-relay — wakes relay when a print job is enqueued (see README Kitchen Relay)
# PRINT_BELL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/PrintBell
# AWS_REGION=us-east-1

# Store times (see root .env.example): STORE_OPEN_TIME, STORE_LAST_CALL_TIME, STORE_CLOSE_TIME, optional STORE_HOURS_OVERRIDE.
# STORE_HOURS_OVERRIDE=2
