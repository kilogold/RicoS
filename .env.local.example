# Local secrets and machine-specific overrides.
# Copy to .env.local at repo root (gitignored).
# Keep non-secret runtime config in .env (ports, printer adapter).

# Stripe — get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook proxy — from `stripe listen` (CLI) or Stripe Dashboard webhook signing secret (production)
STRIPE_WEBHOOK_SECRET=whsec_...

# Webhook proxy — required Turso auth token (secret)
WEBHOOK_PROXY_DATABASE_AUTH_TOKEN=eyJ...

# Optional: relay → proxy print-ack auth (set the same value on webhook-proxy)
# PRINT_ACK_SECRET=change-me

