# Local secrets and machine-specific overrides.
# Copy to .env.local at repo root (gitignored).

# Stripe — get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Kitchen relay — from `stripe listen` (CLI) or Stripe Dashboard webhook signing secret (production)
STRIPE_WEBHOOK_SECRET=whsec_...

# Kitchen relay — required: lp (CUPS) or console (stdout + optional log only; no printer)
KITCHEN_PRINTER_ADAPTER=console
# Optional: CUPS queue name when lp (see `lpstat -p`)
# KITCHEN_PRINTER_NAME=YourKitchenPrinter
# Optional: lp job title
# KITCHEN_PRINTER_TITLE=RicosKitchen
# Optional: append tickets to a file (console adapter only)
# KITCHEN_PRINT_LOG=kitchen-print.log
# Local retries (defaults shown if unset)
# KITCHEN_PRINT_MAX_ATTEMPTS=5
# KITCHEN_PRINT_RETRY_INITIAL_DELAY_MS=200
# Optional: append failed tickets after retries
# KITCHEN_PRINT_DEAD_LETTER=kitchen-print-dead-letter.log
# Optional: path for processed Stripe event ids (default: kitchen-relay/.kitchen-processed-events.json)
# KITCHEN_IDEMPOTENCY_STORE=

